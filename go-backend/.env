# Runtime env: dev / prod
APP_ENV=dev

# Server
SERVER_PORT=8123
SERVER_CONTEXT_PATH=/api

# Session
SESSION_NAME=GO_SESSION
SESSION_MAX_AGE_SECONDS=2592000
SESSION_SECRET=replace-with-your-session-secret
ENCRYPTION_SECRET_KEY=replace-with-your-encryption-secret

# MySQL
MYSQL_DSN=root:123456@tcp(127.0.0.1:3306)/yu_ai_router?charset=utf8mb4&parseTime=true&loc=Local

# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# AI Provider (mvp-ai-router 对齐：通义千问兼容 OpenAI)
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
AI_MODEL=qwen-plus
AI_API_KEY=replace-with-your-real-qwen-api-key
AI_CACHE_ENABLED=true
AI_CACHE_TTL_SECONDS=300

# Stripe (Sandbox)
STRIPE_API_KEY=replace-with-your-stripe-api-key
STRIPE_WEBHOOK_SECRET=replace-with-your-stripe-webhook-secret
STRIPE_SUCCESS_URL=http://localhost:5173/recharge/success
STRIPE_CANCEL_URL=http://localhost:5173/recharge/cancel

# Plugin
PLUGIN_SERPAPI_API_KEY=replace-with-your-serpapi-api-key
