APP_ENV=prod
APP_HOST=0.0.0.0
APP_PORT=8123
APP_BASE_PATH=/api
LOG_LEVEL=INFO

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DB=yu_ai_router
MYSQL_CHARSET=utf8mb4

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
AI_API_KEY=replace-with-your-real-qwen-api-key
AI_MODEL=qwen-plus
AI_CHAT_COMPLETIONS_PATH=/v1/chat/completions
AI_TIMEOUT_SECONDS=120

STRIPE_API_KEY=replace-with-your-stripe-test-api-key
STRIPE_WEBHOOK_SECRET=replace-with-your-stripe-webhook-secret
STRIPE_SUCCESS_URL=http://localhost:5173/recharge/success
STRIPE_CANCEL_URL=http://localhost:5173/recharge/cancel
ENCRYPTION_SECRET_KEY=replace-with-your-32-char-secret-key
PLUGIN_SERPAPI_API_KEY=replace-with-your-serpapi-api-key
